# PostgreSQL
PGDATABASE=contract_agent
PGUSER=contract_agent
PGPASSWORD=replace_with_a_long_random_password

# OpenAI-compatible chat and embedding API
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
OPENAI_API_KEY=replace_with_your_api_key
OPENAI_CHAT_MODEL=qwen-plus
OPENAI_EMBEDDING_MODEL=text-embedding-v3
OPENAI_EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=10

# Optional reranker
RAG_RERANK_ENABLED=false
RAG_RERANK_API_KEY=
ALIYUN_BAILIAN_WORKSPACE_ID=
ALIYUN_BAILIAN_REGION=cn-beijing
RAG_RERANK_MODEL=qwen3-rerank
